.bet-chip.is-active {
  transform: translateY(-2px) scale(1.04);
  filter: brightness(1.08);
}

.bet-chip.is-active::after {
  opacity: 1;
}

.bet-chip--50.is-active,
.bet-chip--250.is-active {
  filter: drop-shadow(0 0 14px rgba(242, 181, 67, 0.22));
}

.bet-chip--100.is-active {
  filter: drop-shadow(0 0 16px rgba(133, 226, 255, 0.25));
}

.bet-chip--100.is-active::after {
  box-shadow: 0 0 16px rgba(91, 219, 255, 0.18);
  border-color: rgba(171, 241, 255, 0.42);
}

.bet-chip--all-in.is-active {
  filter: drop-shadow(0 0 18px rgba(255, 132, 45, 0.24));
}

.bet-chip--all-in.is-active::after {
  border-color: rgba(255, 226, 190, 0.55);
}

.bet-chip:active {
  transform: translateY(1px) scale(0.985);
}

.answer-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  direction: ltr;
}

.answer-button {
  position: relative;
  appearance: none;
  border: none;
  min-height: 70px;
  border-radius: 22px;
  font-size: 24px;
  font-weight: 900;
  cursor: pointer;
  overflow: hidden;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
  transition:
    transform 180ms ease,
    box-shadow 180ms ease,
    filter 180ms ease;
}

.answer-button::before,
.answer-button::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.answer-button::before {
  border-radius: inherit;
  border: 1px solid rgba(255,255,255,0.14);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.15),
    inset 0 -12px 18px rgba(0,0,0,0.28);
}

.answer-button::after {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.16), transparent 28%),
    linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
  opacity: 0.9;
}

.answer-button--lie {
  background:
    radial-gradient(circle at 20% 30%, rgba(255, 187, 109, 0.22), transparent 28%),
    linear-gradient(180deg, #553117 0%, #9b511a 45%, #5f260c 100%);
  box-shadow:
    var(--shadow-soft),
    0 0 22px rgba(255, 138, 53, 0.14);
}

.answer-button--truth {
  background:
    radial-gradient(circle at 80% 30%, rgba(133, 240, 255, 0.2), transparent 28%),
    linear-gradient(180deg, #123955 0%, #1b6fa0 45%, #0d2943 100%);
  box-shadow:
    var(--shadow-soft),
    0 0 22px rgba(75, 215, 255, 0.16);
}

.answer-button:active {
  transform: scale(0.985);
}

.answer-button:hover {
  filter: brightness(1.04);
}

.answer-button__text {
  position: relative;
  z-index: 1;
  display: block;
  text-shadow:
    0 0 8px rgba(255,255,255,0.08),
    0 1px 0 rgba(0,0,0,0.18);
}

.is-pulsing {
  animation: uiPulse 420ms ease;
}

.is-success {
  animation: successGlow 520ms ease;
}

.is-fail {
  animation: failGlow 520ms ease;
}

@keyframes uiPulse {
  0% { transform: scale(1); }
  35% { transform: scale(1.07); }
  100% { transform: scale(1); }
}

@keyframes successGlow {
  0% { filter: brightness(1); }
  35% { filter: brightness(1.14); }
  100% { filter: brightness(1); }
}

@keyframes failGlow {
  0% { filter: brightness(1); }
  35% { filter: brightness(1.08); }
  100% { filter: brightness(1); }
}

@media (max-width: 380px) {
  .game-screen {
    padding-inline: 12px;
    gap: 14px;
  }

  .top-status-bar {
    grid-template-columns: 54px 1fr 108px;
    gap: 8px;
  }

  .badge-icon {
    width: 54px;
    height: 54px;
  }

  .status-pill {
    min-height: 54px;
  }

  .coin-counter {
    grid-template-columns: 44px 1fr;
  }

  .coin-counter__value {
    font-size: 20px;
  }

  .combo-counter__text {
    font-size: 16px;
  }

  .fact-card__content {
    min-height: min(49vh, 430px);
    padding-top: 20px;
  }

  .fact-card__text {
    font-size: 23px;
  }

  .bet-chip > span {
    min-width: 62px;
    min-height: 62px;
  }

  .bet-chip--all-in > span {
    min-width: 72px;
    min-height: 72px;
  }

  .answer-button {
    min-height: 66px;
    font-size: 22px;
  }
}

@media (min-width: 431px) {
  .game-screen {
    padding-inline: 18px;
  }
}

  </style>
</head>
<body>
  <main class="game-screen">
    <section class="top-status-bar" aria-label="סטטוס משחק">
      <div class="badge-icon" aria-hidden="true"></div><div class="status-pill coin-counter" aria-label="מונה ז׳יטונים">
    <div class="coin-counter__icon" aria-hidden="true"></div>
    <div class="coin-counter__text">
      <div class="coin-counter__label">ז׳יטונים</div>
      <div class="coin-counter__value" id="coinValue">1,450</div>
    </div>
  </div>

  <div class="status-pill combo-counter" aria-label="מונה קומבו">
    <div class="combo-counter__text" id="comboValue">Combo x3</div>
  </div>
</section>

<section class="fact-card" aria-label="כרטיס עובדה">
  <div class="fact-card__frame">
    <div class="fact-card__content">
      <div class="fact-card__text" id="factText">
        יום אחד על כוכב נוגה ארוך יותר משנה שלמה על אותו כוכב לכת.
      </div>

      <div class="fact-card__footer">
        <div class="fact-card__label">High Risk Fact</div>

        <div class="fact-card__progress" aria-label="התקדמות">
          <div class="fact-card__progress-fill" id="progressFill" style="width: 38%;"></div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="betting-row" aria-label="בחירת הימור">
  <button class="bet-chip bet-chip--50" type="button" data-bet="50" aria-pressed="false">
    <span>50</span>
  </button>

  <button class="bet-chip bet-chip--100 is-active" type="button" data-bet="100" aria-pressed="true">
    <span>100</span>
  </button>

  <button class="bet-chip bet-chip--250" type="button" data-bet="250" aria-pressed="false">
    <span>250</span>
  </button>

  <button class="bet-chip bet-chip--all-in" type="button" data-bet="all-in" aria-pressed="false">
    <span>ALL-IN</span>
  </button>
</section>

<section class="answer-buttons" aria-label="כפתורי תשובה">
  <button class="answer-button answer-button--lie" id="lieButton" type="button">
    <span class="answer-button__text">שקר</span>
  </button>

  <button class="answer-button answer-button--truth" id="truthButton" type="button">
    <span class="answer-button__text">אמת</span>
  </button>
</section>

  </main>  <script>
    (() => {
      const state = {
        coins: 1450,
        combo: 3,
        selectedBet: 100,
        progress: 38,
        currentFact: "יום אחד על כוכב נוגה ארוך יותר משנה שלמה על אותו כוכב לכת.",
        correctAnswer: "truth"
      };

      const coinValueEl = document.getElementById("coinValue");
      const comboValueEl = document.getElementById("comboValue");
      const progressFillEl = document.getElementById("progressFill");
      const factTextEl = document.getElementById("factText");
      const chipButtons = Array.from(document.querySelectorAll(".bet-chip"));
      const lieButton = document.getElementById("lieButton");
      const truthButton = document.getElementById("truthButton");

      function formatNumber(value) {
        return Number(value).toLocaleString("en-US");
      }

      function pulseElement(element, extraClass) {
        element.classList.remove("is-pulsing", "is-success", "is-fail");
        void element.offsetWidth;
        element.classList.add("is-pulsing");
        if (extraClass) element.classList.add(extraClass);
        setTimeout(() => {
          element.classList.remove("is-pulsing", "is-success", "is-fail");
        }, 560);
      }

      function getBetNumericValue(bet) {
        if (bet === "all-in") return 500;
        return Number(bet) || 0;
      }

      function renderCoins() {
        coinValueEl.textContent = formatNumber(state.coins);
      }

      function renderCombo() {
        comboValueEl.textContent = `Combo x${state.combo}`;
      }

      function renderProgress() {
        const clamped = Math.max(0, Math.min(100, Number(state.progress) || 0));
        progressFillEl.style.width = `${clamped}%`;
      }

      function renderFactText() {
        factTextEl.textContent = state.currentFact;
      }

      function renderSelectedBet() {
        chipButtons.forEach((button) => {
          const value = button.dataset.bet;
          const isActive = String(value) === String(state.selectedBet);
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      }

      function setCoins(value) {
        state.coins = Math.max(0, Number(value) || 0);
        renderCoins();
        pulseElement(coinValueEl, "is-success");
      }

      function setCombo(value) {
        state.combo = Math.max(0, Number(value) || 0);
        renderCombo();
        pulseElement(comboValueEl, "is-success");
      }

      function setProgress(value) {
        state.progress = Math.max(0, Math.min(100, Number(value) || 0));
        renderProgress();
        pulseElement(progressFillEl);
      }

      function setFactText(text) {
        state.currentFact = String(text ?? "");
        renderFactText();
        pulseElement(factTextEl);
      }

      function selectBet(value) {
        const normalized = value === "all-in" ? "all-in" : Number(value);
        state.selectedBet = normalized;
        renderSelectedBet();
        const activeChip = chipButtons.find((button) => String(button.dataset.bet) === String(normalized));
        if (activeChip) pulseElement(activeChip);
      }

      function submitAnswer(answer) {
        const isCorrect = String(answer) === String(state.correctAnswer);
        const betValue = getBetNumericValue(state.selectedBet);

        if (isCorrect) {
          state.coins += betValue;
          state.combo += 1;
          renderCoins();
          renderCombo();
          pulseElement(coinValueEl, "is-success");
          pulseElement(comboValueEl, "is-success");
          pulseElement(answer === "truth" ? truthButton : lieButton, "is-success");
        } else {
          state.coins = Math.max(0, state.coins - betValue);
          state.combo = 0;
          renderCoins();
          renderCombo();
          pulseElement(coinValueEl, "is-fail");
          pulseElement(comboValueEl, "is-fail");
          pulseElement(answer === "truth" ? truthButton : lieButton, "is-fail");
        }
      }

      chipButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectBet(button.dataset.bet);
        });
      });

      lieButton.addEventListener("click", () => submitAnswer("lie"));
      truthButton.addEventListener("click", () => submitAnswer("truth"));

      window.setCoins = setCoins;
      window.setCombo = setCombo;
      window.setProgress = setProgress;
      window.setFactText = setFactText;
      window.selectBet = selectBet;
      window.submitAnswer = submitAnswer;

      renderCoins();
      renderCombo();
      renderProgress();
      renderFactText();
      renderSelectedBet();

      setTimeout(() => {
        setCoins(1700);
        setCombo(4);
      }, 1000);

      setTimeout(() => {
        setProgress(52);
      }, 1500);
    })();
  </script></body>
</html>
