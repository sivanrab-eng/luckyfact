<!DOCTYPE html><html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>LuckyFact - Trivia Round</title>
  <style>
    :root {
      --bg-0: #06111f;
      --bg-1: #09182c;
      --bg-2: #0d2341;
      --panel-0: rgba(14, 33, 57, 0.88);
      --panel-1: rgba(18, 43, 73, 0.92);
      --panel-2: rgba(9, 22, 39, 0.96);
      --line-soft: rgba(133, 194, 255, 0.18);
      --line-strong: rgba(122, 216, 255, 0.5);
      --text-main: #f2f7ff;
      --text-soft: #8fb1d7;
      --cyan: #60e8ff;
      --cyan-2: #2fbfff;
      --cyan-3: #8ff6ff;
      --blue-deep: #132d4f;
      --gold-0: #fff2c9;
      --gold-1: #f8cf70;
      --gold-2: #c98e2c;
      --gold-3: #7b4e10;
      --silver-0: #f8fbff;
      --silver-1: #c8d8ea;
      --silver-2: #8b9cb2;
      --silver-3: #4c5e75;
      --bronze-0: #ffd5a6;
      --bronze-1: #ff9a43;
      --bronze-2: #cf5f1f;
      --bronze-3: #5b2206;
      --danger: #ff9f4c;
      --success: #67ebff;
      --shadow-deep: 0 18px 42px rgba(0, 0, 0, 0.42);
      --shadow-soft: 0 8px 20px rgba(0, 0, 0, 0.24);
      --glow-cyan: 0 0 0 1px rgba(96, 232, 255, 0.18), 0 0 18px rgba(54, 196, 255, 0.2), 0 0 34px rgba(67, 204, 255, 0.12);
      --glow-gold: 0 0 0 1px rgba(248, 207, 112, 0.18), 0 0 18px rgba(248, 181, 59, 0.22), 0 0 34px rgba(241, 160, 51, 0.12);
      --radius-xl: 28px;
      --radius-lg: 22px;
      --radius-md: 18px;
      --radius-sm: 14px;
      --tap-size: 58px;
      --safe-bottom: env(safe-area-inset-bottom, 0px);
      --safe-top: env(safe-area-inset-top, 0px);
    }* {
  box-sizing: border-box;
  -webkit-tap-highlight-color: transparent;
}

html, body {
  margin: 0;
  min-height: 100%;
  font-family: Arial, "Segoe UI", sans-serif;
  background:
    radial-gradient(circle at 50% 12%, rgba(55, 145, 255, 0.16), transparent 28%),
    radial-gradient(circle at 50% 100%, rgba(42, 162, 255, 0.14), transparent 38%),
    linear-gradient(180deg, #07101d 0%, #081525 22%, #0a1930 55%, #091522 100%);
  color: var(--text-main);
}

body {
  display: flex;
  justify-content: center;
  align-items: stretch;
  overflow-x: hidden;
}

body::before,
body::after {
  content: "";
  position: fixed;
  inset: 0;
  pointer-events: none;
}

body::before {
  background:
    linear-gradient(115deg, rgba(255,255,255,0.04) 0%, transparent 22%, transparent 78%, rgba(255,255,255,0.03) 100%),
    repeating-linear-gradient(
      180deg,
      rgba(110, 194, 255, 0.02) 0px,
      rgba(110, 194, 255, 0.02) 1px,
      transparent 1px,
      transparent 10px
    );
  mix-blend-mode: screen;
  opacity: 0.65;
}

body::after {
  background:
    radial-gradient(circle at 50% 0%, rgba(96, 232, 255, 0.12), transparent 30%),
    radial-gradient(circle at 20% 28%, rgba(255, 180, 60, 0.06), transparent 16%),
    radial-gradient(circle at 82% 40%, rgba(95, 226, 255, 0.08), transparent 18%);
}

.game-screen {
  width: min(100%, 430px);
  min-height: 100vh;
  padding:
    calc(18px + var(--safe-top))
    16px
    calc(18px + var(--safe-bottom))
    16px;
  display: grid;
  grid-template-rows: auto 1fr auto auto;
  gap: 16px;
  position: relative;
  isolation: isolate;
}

.game-screen::before {
  content: "";
  position: absolute;
  inset: 10px 8px;
  border-radius: 34px;
  border: 1px solid rgba(141, 203, 255, 0.08);
  box-shadow: inset 0 0 0 1px rgba(255,255,255,0.02);
  pointer-events: none;
}

.top-status-bar {
  display: grid;
  grid-template-columns: 58px 1fr 118px;
  align-items: center;
  gap: 10px;
  direction: ltr;
}

.badge-icon {
  width: 58px;
  height: 58px;
  border: 1px solid rgba(126, 210, 255, 0.25);
  border-radius: 18px;
  background:
    linear-gradient(155deg, rgba(26, 61, 98, 0.96), rgba(9, 22, 37, 0.98)),
    linear-gradient(180deg, rgba(255,255,255,0.06), transparent 35%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.09),
    inset 0 -12px 20px rgba(0,0,0,0.24),
    var(--glow-cyan),
    var(--shadow-soft);
  display: grid;
  place-items: center;
  position: relative;
  overflow: hidden;
}

.badge-icon::before,
.badge-icon::after {
  content: "";
  position: absolute;
  inset: 8px;
  border-radius: 14px;
  pointer-events: none;
}

.badge-icon::before {
  background:
    radial-gradient(circle at 50% 48%, rgba(103, 235, 255, 0.22), transparent 34%),
    linear-gradient(135deg, rgba(255,255,255,0.05), transparent 65%);
  border: 1px solid rgba(156, 225, 255, 0.12);
}

.badge-icon::after {
  inset: 13px 10px;
  border-radius: 50%;
  background:
    radial-gradient(circle at 50% 50%, rgba(120, 240, 255, 0.95) 0 9%, rgba(13, 89, 122, 0.95) 10% 19%, transparent 20%),
    radial-gradient(ellipse at 50% 50%, transparent 0 34%, rgba(117, 235, 255, 0.78) 35% 42%, transparent 43%),
    radial-gradient(ellipse at 50% 50%, rgba(31, 96, 136, 0.95) 0 68%, transparent 69%);
  filter: drop-shadow(0 0 8px rgba(111, 235, 255, 0.3));
  clip-path: polygon(0 50%, 12% 35%, 28% 20%, 50% 12%, 72% 20%, 88% 35%, 100% 50%, 88% 65%, 72% 80%, 50% 88%, 28% 80%, 12% 65%);
}

.status-pill {
  min-height: 58px;
  border-radius: 18px;
  position: relative;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.08), rgba(255,255,255,0.01) 22%, transparent 40%),
    linear-gradient(145deg, rgba(22, 50, 84, 0.96), rgba(10, 24, 43, 0.98));
  border: 1px solid rgba(135, 201, 255, 0.18);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.09),
    inset 0 -10px 22px rgba(0,0,0,0.25),
    var(--shadow-soft);
}

.status-pill::before {
  content: "";
  position: absolute;
  inset: 1px;
  border-radius: inherit;
  border: 1px solid rgba(255,255,255,0.03);
  pointer-events: none;
}

.status-pill::after {
  content: "";
  position: absolute;
  top: 0;
  right: 14px;
  left: 14px;
  height: 1px;
  background: linear-gradient(90deg, transparent, rgba(194, 235, 255, 0.5), transparent);
  opacity: 0.7;
  pointer-events: none;
}

.coin-counter {
  display: grid;
  grid-template-columns: 48px 1fr;
  align-items: center;
  direction: ltr;
}

.coin-counter__icon {
  height: 100%;
  display: grid;
  place-items: center;
  position: relative;
  border-inline-end: 1px solid rgba(245, 196, 90, 0.16);
  background:
    radial-gradient(circle at 50% 35%, rgba(255, 246, 219, 0.18), transparent 48%),
    linear-gradient(180deg, rgba(255, 214, 115, 0.08), rgba(0,0,0,0));
}

.coin-counter__icon::before {
  content: "";
  width: 25px;
  aspect-ratio: 1;
  border-radius: 50%;
  background:
    radial-gradient(circle at 35% 30%, var(--gold-0), transparent 30%),
    radial-gradient(circle at 50% 50%, var(--gold-1), var(--gold-2) 68%, var(--gold-3) 100%);
  border: 1px solid rgba(255, 235, 179, 0.55);
  box-shadow:
    inset 0 2px 2px rgba(255,255,255,0.35),
    inset 0 -3px 5px rgba(70, 31, 0, 0.32),
    0 0 10px rgba(255, 196, 73, 0.24);
  position: relative;
}

.coin-counter__icon::after {
  content: "₵";
  position: absolute;
  font-weight: 800;
  font-size: 13px;
  color: rgba(79, 45, 4, 0.85);
  text-shadow: 0 1px 0 rgba(255,255,255,0.28);
}

.coin-counter__text {
  padding: 8px 12px 7px 12px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  gap: 2px;
  text-align: left;
}

.coin-counter__label {
  font-size: 11px;
  line-height: 1;
  color: #e7c97a;
  letter-spacing: 0.02em;
  opacity: 0.95;
}

.coin-counter__value {
  font-size: clamp(22px, 5vw, 26px);
  line-height: 1;
  font-weight: 800;
  color: #fff6da;
  text-shadow:
    0 0 10px rgba(255, 197, 71, 0.15),
    0 1px 0 rgba(255,255,255,0.08);
  font-variant-numeric: tabular-nums;
}

.combo-counter {
  display: grid;
  place-items: center;
  box-shadow: var(--shadow-soft), var(--glow-cyan);
}

.combo-counter__text {
  font-size: clamp(17px, 4vw, 20px);
  font-weight: 800;
  letter-spacing: 0.03em;
  color: var(--cyan-3);
  text-shadow:
    0 0 8px rgba(96, 232, 255, 0.35),
    0 0 18px rgba(62, 209, 255, 0.24);
  text-align: center;
  direction: ltr;
}

.fact-card {
  position: relative;
  min-height: 0;
  display: flex;
}

.fact-card__frame {
  width: 100%;
  position: relative;
  border-radius: 30px;
  padding: 18px;
  background:
    radial-gradient(circle at 50% 0%, rgba(118, 231, 255, 0.1), transparent 28%),
    linear-gradient(180deg, rgba(23, 52, 87, 0.95), rgba(10, 23, 40, 0.98) 44%, rgba(7, 18, 31, 1));
  border: 1px solid rgba(124, 196, 255, 0.22);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.09),
    inset 0 -18px 26px rgba(0, 0, 0, 0.28),
    0 0 0 1px rgba(92, 165, 222, 0.06),
    var(--shadow-deep),
    0 0 28px rgba(38, 161, 255, 0.1);
  overflow: hidden;
  display: flex;
}

.fact-card__frame::before,
.fact-card__frame::after {
  content: "";
  position: absolute;
  pointer-events: none;
}

.fact-card__frame::before {
  inset: 10px;
  border-radius: 22px;
  border: 1px solid rgba(172, 225, 255, 0.09);
  box-shadow:
    inset 0 0 0 1px rgba(255,255,255,0.02),
    inset 0 10px 20px rgba(255,255,255,0.02);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.025), transparent 22%),
    linear-gradient(135deg, transparent 0 6%, rgba(127, 205, 255, 0.06) 6% 8%, transparent 8% 92%, rgba(127, 205, 255, 0.05) 92% 94%, transparent 94%);
}

.fact-card__frame::after {
  inset: 0;
  background:
    linear-gradient(135deg, rgba(136, 215, 255, 0.12), transparent 14%),
    linear-gradient(315deg, rgba(136, 215, 255, 0.08), transparent 14%),
    radial-gradient(circle at 50% 100%, rgba(96, 232, 255, 0.08), transparent 32%);
  opacity: 0.8;
}

.fact-card__content {
  position: relative;
  z-index: 1;
  width: 100%;
  border-radius: 24px;
  background:
    linear-gradient(180deg, rgba(15, 34, 58, 0.55), rgba(7, 17, 30, 0.72));
  padding: clamp(24px, 5vw, 30px) 18px 18px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  gap: 18px;
  min-height: min(52vh, 470px);
}

.fact-card__text {
  flex: 1;
  display: grid;
  place-items: center;
  font-size: clamp(25px, 5.6vw, 33px);
  line-height: 1.45;
  font-weight: 800;
  text-align: center;
  color: var(--text-main);
  text-shadow:
    0 1px 0 rgba(255,255,255,0.08),
    0 0 18px rgba(75, 185, 255, 0.08);
  padding-inline: 4px;
  word-break: break-word;
}

.fact-card__footer {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.fact-card__label {
  align-self: center;
  padding: 8px 14px;
  border-radius: 999px;
  font-size: 11px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: #d6efff;
  border: 1px solid rgba(122, 216, 255, 0.14);
  background:
    linear-gradient(180deg, rgba(104, 221, 255, 0.08), rgba(17, 55, 85, 0.06));
  box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
}

.fact-card__progress {
  width: 100%;
  height: 14px;
  border-radius: 999px;
  background:
    linear-gradient(180deg, rgba(7, 19, 31, 0.94), rgba(13, 30, 48, 0.96));
  border: 1px solid rgba(123, 201, 255, 0.14);
  padding: 2px;
  box-shadow:
    inset 0 2px 6px rgba(0,0,0,0.35),
    inset 0 1px 0 rgba(255,255,255,0.04);
  overflow: hidden;
  position: relative;
}

.fact-card__progress::before {
  content: "";
  position: absolute;
  inset: 2px;
  border-radius: inherit;
  background: linear-gradient(90deg, rgba(255,255,255,0.025), transparent 30%, transparent 70%, rgba(255,255,255,0.03));
  pointer-events: none;
}

.fact-card__progress-fill {
  width: 38%;
  height: 100%;
  border-radius: inherit;
  background:
    linear-gradient(90deg, #37b9ff 0%, #63ecff 48%, #89ffff 100%);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.35),
    0 0 12px rgba(72, 224, 255, 0.42),
    0 0 24px rgba(48, 188, 255, 0.22);
  position: relative;
  transition: width 320ms ease, box-shadow 220ms ease, transform 220ms ease;
}

.fact-card__progress-fill::after {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: inherit;
  background:
    linear-gradient(180deg, rgba(255,255,255,0.28), rgba(255,255,255,0.04) 48%, transparent 60%);
  pointer-events: none;
}

.betting-row {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10px;
  align-items: end;
  direction: ltr;
}

.bet-chip {
  appearance: none;
  border: none;
  padding: 0;
  background: none;
  color: inherit;
  cursor: pointer;
  position: relative;
  display: grid;
  place-items: center;
  min-height: 82px;
  transition: transform 180ms ease, filter 180ms ease;
}

.bet-chip::before,
.bet-chip::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  transition: inherit;
}

.bet-chip::before {
  inset: 5px;
  box-shadow:
    inset 0 2px 4px rgba(255,255,255,0.28),
    inset 0 -8px 12px rgba(0,0,0,0.32),
    0 8px 18px rgba(0,0,0,0.25);
  border: 1px solid rgba(255,255,255,0.18);
}

.bet-chip::after {
  inset: 13px;
  border: 2px dashed rgba(255,255,255,0.22);
  opacity: 0.7;
}

.bet-chip > span {
  position: relative;
  z-index: 1;
  min-width: 68px;
  min-height: 68px;
  padding: 0 8px;
  display: grid;
  place-items: center;
  text-align: center;
  font-weight: 900;
  line-height: 1;
  letter-spacing: 0.02em;
  text-shadow: 0 1px 0 rgba(255,255,255,0.12);
  user-select: none;
}

.bet-chip--50::before,
.bet-chip--250::before {
  background:
    radial-gradient(circle at 35% 30%, rgba(255, 245, 211, 0.95), transparent 28%),
    linear-gradient(180deg, #ffdd8f 0%, #d0932f 48%, #75440d 100%);
}

.bet-chip--100::before {
  background:
    radial-gradient(circle at 35% 30%, rgba(255,255,255,0.95), transparent 28%),
    linear-gradient(180deg, #edf4fb 0%, #a5b8cd 48%, #53667d 100%);
}

.bet-chip--50 > span,
.bet-chip--250 > span {
  color: #44280a;
  font-size: 22px;
}

.bet-chip--100 > span {
  color: #19324b;
  font-size: 22px;
}

.bet-chip--all-in {
  min-height: 94px;
}

.bet-chip--all-in::before {
  inset: 1px;
  background:
    radial-gradient(circle at 35% 26%, rgba(255, 240, 214, 0.9), transparent 24%),
    linear-gradient(180deg, #ffcf82 0%, #ff8d32 38%, #942f09 72%, #431104 100%);
  box-shadow:
    inset 0 2px 4px rgba(255,255,255,0.26),
    inset 0 -10px 14px rgba(0,0,0,0.34),
    0 10px 22px rgba(0,0,0,0.28),
    0 0 24px rgba(255, 129, 41, 0.18);
}

.bet-chip--all-in::after {
  inset: 11px;
  border: 2px solid rgba(255, 216, 174, 0.3);
  box-shadow: 0 0 16px rgba(255, 157, 63, 0.18);
}

.bet-chip--all-in > span {
  min-width: 78px;
  min-height: 78px;
  color: #fff3e1;
  font-size: 16px;
  letter-spacing: 0.08em;
  text-shadow:
    0 0 10px rgba(255, 200, 114, 0.2),
    0 1px 0 rgba(0,0,0,0.15);
}

.bet-chip.is-active {
  transform: translateY(-2px) scale(1.04);
  filter: brightness(1.08);
}

.bet-chip.is-active::after {
  opacity: 1;
}

.bet-chip--50.is-active,
.bet-chip--250.is-active {
  filter: drop-shadow(0 0 14px rgba(242, 181, 67, 0.22));
}

.bet-chip--100.is-active {
  filter: drop-shadow(0 0 16px rgba(133, 226, 255, 0.25));
}

.bet-chip--100.is-active::after {
  box-shadow: 0 0 16px rgba(91, 219, 255, 0.18);
  border-color: rgba(171, 241, 255, 0.42);
}

.bet-chip--all-in.is-active {
  filter: drop-shadow(0 0 18px rgba(255, 132, 45, 0.24));
}

.bet-chip--all-in.is-active::after {
  border-color: rgba(255, 226, 190, 0.55);
}

.bet-chip:active {
  transform: translateY(1px) scale(0.985);
}

.answer-buttons {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  direction: ltr;
}

.answer-button {
  position: relative;
  appearance: none;
  border: none;
  min-height: 70px;
  border-radius: 22px;
  font-size: 24px;
  font-weight: 900;
  cursor: pointer;
  overflow: hidden;
  color: var(--text-main);
  box-shadow: var(--shadow-soft);
  transition:
    transform 180ms ease,
    box-shadow 180ms ease,
    filter 180ms ease;
}

.answer-button::before,
.answer-button::after {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.answer-button::before {
  border-radius: inherit;
  border: 1px solid rgba(255,255,255,0.14);
  box-shadow:
    inset 0 1px 0 rgba(255,255,255,0.15),
    inset 0 -12px 18px rgba(0,0,0,0.28);
}

.answer-button::after {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.16), transparent 28%),
    linear-gradient(90deg, transparent, rgba(255,255,255,0.05), transparent);
  opacity: 0.9;
}

.answer-button--lie {
  background:
    radial-gradient(circle at 20% 30%, rgba(255, 187, 109, 0.22), transparent 28%),
    linear-gradient(180deg, #553117 0%, #9b511a 45%, #5f260c 100%);
  box-shadow:
    var(--shadow-soft),
    0 0 22px rgba(255, 138, 53, 0.14);
}

.answer-button--truth {
  background:
    radial-gradient(circle at 80% 30%, rgba(133, 240, 255, 0.2), transparent 28%),
    linear-gradient(180deg, #123955 0%, #1b6fa0 45%, #0d2943 100%);
  box-shadow:
    var(--shadow-soft),
    0 0 22px rgba(75, 215, 255, 0.16);
}

.answer-button:active {
  transform: scale(0.985);
}

.answer-button:hover {
  filter: brightness(1.04);
}

.answer-button__text {
  position: relative;
  z-index: 1;
  display: block;
  text-shadow:
    0 0 8px rgba(255,255,255,0.08),
    0 1px 0 rgba(0,0,0,0.18);
}

.is-pulsing {
  animation: uiPulse 420ms ease;
}

.is-success {
  animation: successGlow 520ms ease;
}

.is-fail {
  animation: failGlow 520ms ease;
}

@keyframes uiPulse {
  0% { transform: scale(1); }
  35% { transform: scale(1.07); }
  100% { transform: scale(1); }
}

@keyframes successGlow {
  0% { filter: brightness(1); }
  35% { filter: brightness(1.14); }
  100% { filter: brightness(1); }
}

@keyframes failGlow {
  0% { filter: brightness(1); }
  35% { filter: brightness(1.08); }
  100% { filter: brightness(1); }
}

@media (max-width: 380px) {
  .game-screen {
    padding-inline: 12px;
    gap: 14px;
  }

  .top-status-bar {
    grid-template-columns: 54px 1fr 108px;
    gap: 8px;
  }

  .badge-icon {
    width: 54px;
    height: 54px;
  }

  .status-pill {
    min-height: 54px;
  }

  .coin-counter {
    grid-template-columns: 44px 1fr;
  }

  .coin-counter__value {
    font-size: 20px;
  }

  .combo-counter__text {
    font-size: 16px;
  }

  .fact-card__content {
    min-height: min(49vh, 430px);
    padding-top: 20px;
  }

  .fact-card__text {
    font-size: 23px;
  }

  .bet-chip > span {
    min-width: 62px;
    min-height: 62px;
  }

  .bet-chip--all-in > span {
    min-width: 72px;
    min-height: 72px;
  }

  .answer-button {
    min-height: 66px;
    font-size: 22px;
  }
}

@media (min-width: 431px) {
  .game-screen {
    padding-inline: 18px;
  }
}

  </style>
</head>
<body>
  <main class="game-screen">
    <section class="top-status-bar" aria-label="סטטוס משחק">
      <div class="badge-icon" aria-hidden="true"></div><div class="status-pill coin-counter" aria-label="מונה ז׳יטונים">
