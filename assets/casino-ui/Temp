    (() => {
      const state = {
        coins: 1450,
        combo: 3,
        selectedBet: 100,
        progress: 38,
        currentFact: "יום אחד על כוכב נוגה ארוך יותר משנה שלמה על אותו כוכב לכת.",
        correctAnswer: "truth"
      };

      const coinValueEl = document.getElementById("coinValue");
      const comboValueEl = document.getElementById("comboValue");
      const progressFillEl = document.getElementById("progressFill");
      const factTextEl = document.getElementById("factText");
      const chipButtons = Array.from(document.querySelectorAll(".bet-chip"));
      const lieButton = document.getElementById("lieButton");
      const truthButton = document.getElementById("truthButton");

      function formatNumber(value) {
        return Number(value).toLocaleString("en-US");
      }

      function pulseElement(element, extraClass) {
        element.classList.remove("is-pulsing", "is-success", "is-fail");
        void element.offsetWidth;
        element.classList.add("is-pulsing");
        if (extraClass) element.classList.add(extraClass);
        setTimeout(() => {
          element.classList.remove("is-pulsing", "is-success", "is-fail");
        }, 560);
      }

      function getBetNumericValue(bet) {
        if (bet === "all-in") return 500;
        return Number(bet) || 0;
      }

      function renderCoins() {
        coinValueEl.textContent = formatNumber(state.coins);
      }

      function renderCombo() {
        comboValueEl.textContent = `Combo x${state.combo}`;
      }

      function renderProgress() {
        const clamped = Math.max(0, Math.min(100, Number(state.progress) || 0));
        progressFillEl.style.width = `${clamped}%`;
      }

      function renderFactText() {
        factTextEl.textContent = state.currentFact;
      }

      function renderSelectedBet() {
        chipButtons.forEach((button) => {
          const value = button.dataset.bet;
          const isActive = String(value) === String(state.selectedBet);
          button.classList.toggle("is-active", isActive);
          button.setAttribute("aria-pressed", isActive ? "true" : "false");
        });
      }

      function setCoins(value) {
        state.coins = Math.max(0, Number(value) || 0);
        renderCoins();
        pulseElement(coinValueEl, "is-success");
      }

      function setCombo(value) {
        state.combo = Math.max(0, Number(value) || 0);
        renderCombo();
        pulseElement(comboValueEl, "is-success");
      }

      function setProgress(value) {
        state.progress = Math.max(0, Math.min(100, Number(value) || 0));
        renderProgress();
        pulseElement(progressFillEl);
      }

      function setFactText(text) {
        state.currentFact = String(text ?? "");
        renderFactText();
        pulseElement(factTextEl);
      }

      function selectBet(value) {
        const normalized = value === "all-in" ? "all-in" : Number(value);
        state.selectedBet = normalized;
        renderSelectedBet();
        const activeChip = chipButtons.find((button) => String(button.dataset.bet) === String(normalized));
        if (activeChip) pulseElement(activeChip);
      }

      function submitAnswer(answer) {
        const isCorrect = String(answer) === String(state.correctAnswer);
        const betValue = getBetNumericValue(state.selectedBet);

        if (isCorrect) {
          state.coins += betValue;
          state.combo += 1;
          renderCoins();
          renderCombo();
          pulseElement(coinValueEl, "is-success");
          pulseElement(comboValueEl, "is-success");
          pulseElement(answer === "truth" ? truthButton : lieButton, "is-success");
        } else {
          state.coins = Math.max(0, state.coins - betValue);
          state.combo = 0;
          renderCoins();
          renderCombo();
          pulseElement(coinValueEl, "is-fail");
          pulseElement(comboValueEl, "is-fail");
          pulseElement(answer === "truth" ? truthButton : lieButton, "is-fail");
        }
      }

      chipButtons.forEach((button) => {
        button.addEventListener("click", () => {
          selectBet(button.dataset.bet);
        });
      });

      lieButton.addEventListener("click", () => submitAnswer("lie"));
      truthButton.addEventListener("click", () => submitAnswer("truth"));

      window.setCoins = setCoins;
      window.setCombo = setCombo;
      window.setProgress = setProgress;
      window.setFactText = setFactText;
      window.selectBet = selectBet;
      window.submitAnswer = submitAnswer;

      renderCoins();
      renderCombo();
      renderProgress();
      renderFactText();
      renderSelectedBet();

      setTimeout(() => {
        setCoins(1700);
        setCombo(4);
      }, 1000);

      setTimeout(() => {
        setProgress(52);
      }, 1500);
    })();
